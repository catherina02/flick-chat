# Copy these into Render → flick-chat-api → Environment
# (Or redeploy Blueprint — render.yaml already includes these)

DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
DB_SSL_REQUIRE=True
SECURE_SSL_REDIRECT=False

ALLOWED_HOSTS=flick-chat-api.onrender.com
SITE_URL=https://flick-chat-api.onrender.com

# DATABASE_URL is auto-linked from flick-chat-db — do not paste manually

CORS_ALLOWED_ORIGINS=https://flick-chat.vercel.app,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://flick-chat.vercel.app

# Optional
REDIS_URL=
FCM_SERVER_KEY=

# Demo accounts (auto-created on deploy via create_demo_accounts)
# alice@demo.com / DemoPass123!
# bob@demo.com   / DemoPass123!
# charlie@demo.com / DemoPass123!
